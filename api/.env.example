# Copy to .env and edit. Optional — omit to use the full default list in app/config.py.

# Override the watchlist (comma-separated). Do NOT use DEFAULT_TICKERS; it often
# collides with shell exports from tutorials (e.g. five tickers only).
# STOCK_EARNINGS_DEFAULT_TICKERS=AAPL,MSFT,GOOGL

# DATABASE_URL=sqlite:///./earnings.db
